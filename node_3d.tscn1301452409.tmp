[sub_resource type="GDScript" id="GDScript_nslhu"]
script/source = "extends CharacterBody3D #this tells to the code that is part of CharacterBody3D NOT THE NODES OF IT


const SPEED = 1.0 #speed
const JUMP_VELOCITY = 1.0 #how high the jump is

var speed: float = 67.0
var acceleration1: float = 0.2
var acceleration2: float = 0.2
var frictionx: float = 5.0
var frictionz: float = 5.0

func _physics_process(delta: float) -> void:
	##X axis accel
	var x_input: float = Input.get_action_strength(\"ui_right\") - Input.get_action_strength(\"ui_left\")
	var velocity_weight: float = delta * (acceleration1 if x_input else frictionx)
	velocity.x = lerp(velocity.x, x_input * speed, velocity_weight)
	
	##Z axis accel
	var z_input: float = Input.get_action_strength(\"ui_down\") - Input.get_action_strength(\"ui_up\")
	var velocity_weight2: float = delta * (acceleration2 if z_input else frictionz)
	velocity.z = lerp(velocity.z, z_input * speed, velocity_weight2)
	
	
	if Input.is_action_pressed(\"ui_accept\"):
		velocity.y = JUMP_VELOCITY
	if Input.is_action_pressed(\"shift\"):
		velocity.y = -JUMP_VELOCITY

	move_and_slide()
"

